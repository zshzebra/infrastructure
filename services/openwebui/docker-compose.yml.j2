services:
  openwebui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: openwebui
    restart: unless-stopped
    volumes:
      - open-webui:/app/backend/data
    networks:
      - app-network
    environment:
      - OPENAI_API_BASE_URL=http://litellm:4000
{% if litellm_virtual_key is defined and litellm_virtual_key | length > 0 %}
      - OPENAI_API_KEY={{ litellm_virtual_key }}
{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 120s

  tunnel:
    image: cloudflare/cloudflared:latest
    container_name: openwebui-tunnel
    restart: unless-stopped
    command: tunnel run
    environment:
      - TUNNEL_TOKEN={{ tunnel_token }}
    networks:
      - app-network
      - internet-access

  litellm:
    image: docker.litellm.ai/berriai/litellm:main-stable
    restart: unless-stopped
    ports:
      - "127.0.0.1:4000:4000"
    volumes:
      - ./litellm_config.yaml:/app/config.yaml
    environment:
      DATABASE_URL: "postgresql://llmproxy:{{ litellm_db_password }}@db:5432/litellm"
      STORE_MODEL_IN_DB: "True"
      LITELLM_MASTER_KEY: "{{ litellm_master_key }}"
      ANTHROPIC_API_KEY: "{{ anthropic_api_key }}"
    command: ["--config", "/app/config.yaml"]
    depends_on:
      db:
        condition: service_healthy
    networks:
      - app-network
      - internet-access
    healthcheck:
      test:
        - CMD-SHELL
        - python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:4000/health/liveliness')"
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  db:
    image: postgres:16
    restart: unless-stopped
    container_name: litellm_db
    environment:
      POSTGRES_DB: litellm
      POSTGRES_USER: llmproxy
      POSTGRES_PASSWORD: "{{ litellm_db_password }}"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - app-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -d litellm -U llmproxy"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  prometheus:
    image: prom/prometheus
    restart: unless-stopped
    volumes:
      - prometheus_data:/prometheus
      - ./prometheus.yml:/etc/prometheus/prometheus.yml
    ports:
      - "127.0.0.1:9090:9090"
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time=15d"
    networks:
      - app-network

networks:
  app-network:
    driver: bridge
    internal: true
  internet-access:
    driver: bridge

volumes:
  open-webui:
    name: openwebui_open-webui
  prometheus_data:
    driver: local
  postgres_data:
    name: litellm_postgres_data
